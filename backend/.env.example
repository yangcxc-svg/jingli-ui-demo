APP_ENV=development
APP_DEBUG=true
API_PREFIX=/api
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# mock uses local deterministic responses; set provider/model/key for real LLM calls.
LLM_PROVIDER=mock
LLM_MODEL=mock-guide
LLM_API_KEY=
LLM_BASE_URL=

SEED_PRODUCTS_PATH=../storage/sample_docs/seed_products.json
UPLOAD_DIR=storage/uploads
